rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/notes/{noteId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/categories/{categoryId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
